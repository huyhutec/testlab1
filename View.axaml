<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:MangaReader2026.MangaList"
        xmlns:vc="clr-namespace:MangaReader2026.ViewCommon"
        mc:Ignorable="d"
        d:DesignWidth="800" d:DesignHeight="550"
        x:Class="MangaReader2026.MangaList.View"
        Title="MangaReader - MangaList">

    <Grid>
        <!-- Loading -->
        <ProgressBar Name="LoadingProgressBar"
                     IsIndeterminate="True"
                     HorizontalAlignment="Center"
                     VerticalAlignment="Center"
                     IsVisible="False" />

        <!-- Error -->
        <vc:ErrorPanel Name="ErrorPanel" IsVisible="False" />

        <!-- Main Content -->
        <DockPanel Name="MainContent" IsVisible="False">
            <!-- Thanh trên: số manga + nút phân trang -->
            <StackPanel DockPanel.Dock="Top" Orientation="Horizontal" Spacing="10" Margin="10" HorizontalAlignment="Center">
                <TextBlock Name="TotalMangaNumberLabel" FontSize="18" FontWeight="Bold" VerticalAlignment="Center" />
                <Button Name="FirstButton" Click="FirstButton_OnClick">&lt;&lt;</Button>
                <Button Name="PrevButton" Click="PrevButton_OnClick">&lt; Prev</Button>
                <Button Name="CurrentPageButton" Click="CurrentPageButton_OnClick" Background="DarkOrange" Foreground="Black" />
                <Button Name="NextButton" Click="NextButton_OnClick">Next &gt;</Button>
                <Button Name="LastButton" Click="LastButton_OnClick">&gt;&gt;</Button>
                <Button Name="RefreshButton" Click="RefreshButton_OnClick">Refresh</Button>
            </StackPanel>

            <!-- Ô tìm kiếm -->
            <StackPanel DockPanel.Dock="Top" Orientation="Horizontal" Spacing="10" Margin="10" HorizontalAlignment="Center">
                <TextBox Name="FilterTextBox" Width="300" Watermark="Nhập tên manga rồi nhấn Enter" KeyUp="FilterTextBox_OnKeyUp" />
                <Button Name="ClearButton" Click="ClearButton_OnClick">Clear</Button>
                <Button Name="ApplyButton" Click="ApplyButton_OnClick">Apply</Button>
            </StackPanel>

            <!-- Chọn trang -->
            <NumericUpDown Name="NumericUpDown" Minimum="1" Value="1" KeyUp="NumericUpDown_OnKeyUp" HorizontalAlignment="Center" Margin="10" />

            <!-- Danh sách -->
            <ListBox Name="MangaListBox" DoubleTapped="MyListBox_OnDoubleTapped" KeyUp="MyListBox_OnKeyUp" Margin="10" />
        </DockPanel>
    </Grid>
</Window>